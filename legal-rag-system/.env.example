# ========== DeepSeek API 配置（必填）==========
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ========== LLM 参数 ==========
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
TEMPERATURE=0.3
MAX_TOKENS=4096

# ========== Agent 参数 ==========
MAX_REACT_STEPS=8
MAX_REFLECTION_ITERATIONS=3

# ========== RAG 参数 ==========
RAG_TOP_K=5
CHROMA_PERSIST_DIR=./data/chroma

# ========== 系统参数 ==========
DEBUG=false
LOG_LEVEL=INFO
